{
  "manifest_version": 3,
  "name": "VOICE-TASK-MASTER (VTM)",
  "version": "1.5.1",
  "description": "Voice-first task manager for high-intensity developers. Integrated Ship Mode for Flavortown.",
  "author": "EngThi // Hacker",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://flavortown.hackclub.com/*"
      ],
      "js": [
        "i18n.js",
        "content.js"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    },
    "activate-voice": {
      "suggested_key": {
        "default": "Ctrl+Shift+V"
      },
      "description": "Activate Neural Voice Uplink"
    }
  },
  "offline_enabled": true,
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "permissions.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
