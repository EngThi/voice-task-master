{
  "manifest_version": 3,
  "name": "VOICE-TASK-MASTER (VTM)",
  "version": "1.6.9",
  "description": "Voice-first task manager for high-intensity developers.",
  "author": "EngThi // Hacker",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "offscreen"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [ "*://flavortown.hackclub.com/*" ],
      "js": [ "src/i18n.js", "src/content.js" ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+Y" }
    },
    "activate-voice": {
      "suggested_key": { "default": "Ctrl+Shift+V" },
      "description": "Start voice capture"
    },
    "quick-save-context": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "Save current project context without confirmation"
    }
  },
  "background": { "service_worker": "src/background.js" }
}
